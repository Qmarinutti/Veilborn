# Variables d'environnement (a definir sur l'hebergeur, PAS a committer).
# En local, si elles sont absentes, le jeu utilise un simple fichier "data.db".

# Base de donnees Turso (https://turso.tech) :
TURSO_DATABASE_URL=libsql://ton-app-xxxxx.turso.io
TURSO_AUTH_TOKEN=ton_token_secret

# Port (optionnel, defaut 3000). Render le definit automatiquement.
# PORT=3000
